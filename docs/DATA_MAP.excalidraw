      "roundness": null,
      "seed": 100312,
      "version": 1,
      "versionNonce": 100313,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "✋ = ต้องแก้มือจริง    ⚠️ = จุดเสี่ยงที่ควรรู้    ❌ = ยังไม่มีอยู่จริง    🗑️ = ถูกลบ/แทนที่แล้ว",
      "fontSize": 12.5,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 8.5,
      "containerId": null,
      "originalText": "✋ = ต้องแก้มือจริง    ⚠️ = จุดเสี่ยงที่ควรรู้    ❌ = ยังไม่มีอยู่จริง    🗑️ = ถูกลบ/แทนที่แล้ว",
      "lineHeight": 1.3
    },
    {
      "id": "text_158",
      "type": "text",
      "x": 60,
      "y": 1940,
      "width": 1600,
      "height": 20,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
