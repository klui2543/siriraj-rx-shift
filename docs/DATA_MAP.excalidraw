    {
      "id": "text_34",
      "type": "text",
      "x": 72,
      "y": 547,
      "width": 336,
      "height": 102,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
