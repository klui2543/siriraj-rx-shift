      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10.5,
      "containerId": null,
      "originalText": "คู่มือตำแหน่ง/รายชื่อ  ✋ แก้มือ",
      "lineHeight": 1.3
    },
    {
      "id": "text_31",
      "type": "text",
      "x": 72,
      "y": 402,
      "width": 336,
      "height": 85,
      "angle": 0,
      "strokeColor": "#1e1e1e",
